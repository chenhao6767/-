<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.autoclicker">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Keep CPU awake while loop is running in background -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Required for notification on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AutoClicker">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Accessibility service: injects tap gestures (no ROOT needed) -->
        <service
            android:name=".ClickAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Background runner: keeps the process alive when app is minimised -->
        <service
            android:name=".BackgroundRunnerService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false" />

        <!-- Floating overlay for coordinate capture -->
        <service
            android:name=".FloatingWindowService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Floating crop overlay for image template capture -->
        <service
            android:name=".CropOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Foreground service that keeps MediaProjection alive -->
        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

    </application>
</manifest>
